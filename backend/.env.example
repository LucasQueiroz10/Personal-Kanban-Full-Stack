# Copie este arquivo para ".env" e preencha com seus valores reais.
# NUNCA suba o arquivo ".env" para o GitHub (ele já está no .gitignore).

# Connection string do banco PostgreSQL (Neon, Supabase, ou local)
# Exemplo Neon: postgresql://usuario:senha@host.neon.tech/nomedobanco?sslmode=require
DATABASE_URL="postgresql://usuario:senha@host/nomedobanco?sslmode=require"

# Chave secreta usada para assinar os tokens JWT.
# Gere uma string longa e aleatória, por exemplo com: openssl rand -hex 32
JWT_SECRET="troque_isso_por_uma_string_aleatoria_bem_grande"

# Porta em que o servidor Express vai rodar
PORT=3001

# URL onde o frontend está rodando (usado para liberar CORS)
FRONTEND_URL="http://localhost:5173"
